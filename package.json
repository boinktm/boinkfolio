{
  "name": "boinkfolio",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "content:app": "powershell -ExecutionPolicy Bypass -File ./scripts/content-manager.ps1",
    "content:exe:build": "powershell -ExecutionPolicy Bypass -File ./scripts/build-content-manager-exe.ps1",
    "content:exe": "start \"\" .\\desktop-app\\BoinkfolioContentManager.exe",
    "push:update:ui": "powershell -ExecutionPolicy Bypass -File ./scripts/push-update-ui.ps1",
    "push:update": "powershell -ExecutionPolicy Bypass -File ./scripts/push-update.ps1",
    "push:update:dry": "powershell -ExecutionPolicy Bypass -File ./scripts/push-update.ps1 -DryRun"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.17.1",
    "fast-xml-parser": "^5.4.1",
    "tailwindcss": "^4.2.1"
  }
}
