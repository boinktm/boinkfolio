---
/**
 * ContentGrid — Two-column tabbed content lists
 * Mirrors the "Top Games / News & Press" bottom section of PS.com
 * Left: recent tracks/art | Right: blog musings
 */
import { fetchSoundCloudTracks } from '../lib/soundcloud';
import { getCollection } from 'astro:content';
import { assetPath, musingPath, withBase } from '../lib/paths';

// Fetch real SoundCloud uploads at build time (falls back to hardcoded data on failure)
const SOUNDCLOUD_USER_ID = import.meta.env.SOUNDCLOUD_USER_ID || '70328358';
const tracks = await fetchSoundCloudTracks(SOUNDCLOUD_USER_ID, 6);
const assetEntries = await getCollection('assets');
const musingEntries = await getCollection('musings');

const publicAssets = assetEntries
  .filter(entry => entry.data.isPublic)
  .map(entry => {
  const filePath = entry.data.filePath;
  const fileName = filePath.split('/').pop() ?? filePath;
  const extension = fileName.includes('.')
    ? fileName.split('.').pop()?.toUpperCase() ?? 'FILE'
    : 'FILE';

  return {
    slug: entry.id,
    title: entry.data.title,
    category: entry.data.category,
    date: entry.data.date,
    fileName,
    extension,
  };
});

const posts = musingEntries
  .map(entry => ({
    slug: entry.id,
    ...entry.data,
  }))
  .slice(0, 3);
---

<section id="musings" class="bg-obsidian py-8">
  <div class="max-w-[var(--width-content)] mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-4">

    <!-- Left Column: Tracks / Art List -->
    <div class="surface-card rounded-sm overflow-hidden" id="track-player">
      <div class="flex border-b border-border">
        <button
          id="tracks-tab-btn"
          class="px-5 py-3 text-[10px] font-bold uppercase tracking-widest transition-colors tab-active bg-surface"
        >
          Recent Tracks
        </button>
        <button
          id="assets-tab-btn"
          class="px-5 py-3 text-[10px] font-bold uppercase tracking-widest transition-colors text-text-muted hover:text-text-secondary bg-charcoal"
        >
          Public Assets
        </button>
      </div>

      <div id="tracks-panel">
        <div class="divide-y divide-border" id="track-list">
          {tracks.map((track, index) => (
            <div
              class="track-row flex items-center gap-4 px-5 py-4 hover:bg-surface-hover transition-colors group cursor-pointer"
              data-index={index}
              data-stream={track.streamUrl}
              data-title={track.title}
              data-subtitle={track.subtitle}
              data-artwork={track.artwork}
              data-href={track.href}
              data-duration={track.duration}
            >
              <div class="relative w-12 h-12 flex-shrink-0">
                {track.artwork ? (
                  <img
                    src={track.artwork}
                    alt={track.title}
                    class="w-12 h-12 rounded-sm border border-border group-hover:border-accent/40 transition-colors object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-12 h-12 bg-charcoal rounded-sm border border-border group-hover:border-accent/40 transition-colors"></div>
                )}
                <div class="track-play-overlay absolute inset-0 flex items-center justify-center bg-black/50 rounded-sm opacity-0 group-hover:opacity-100 transition-opacity">
                  <svg class="play-icon w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                  <svg class="pause-icon w-5 h-5 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
                  </svg>
                </div>
              </div>

              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-text-primary truncate">{track.title}</p>
                <p class="text-xs text-text-muted">
                  {track.subtitle}
                  {track.duration && <span class="ml-2 text-text-muted/60">· {track.duration}</span>}
                </p>
              </div>

              {track.badge && (
                <span class="text-[9px] font-bold uppercase tracking-wider bg-accent/20 text-accent px-2 py-0.5 rounded-sm">
                  {track.badge}
                </span>
              )}

              <a
                href={track.href}
                target="_blank"
                rel="noopener noreferrer"
                class="sc-link text-text-muted hover:text-accent transition-colors opacity-0 group-hover:opacity-100"
                title="Open on SoundCloud"
                onclick="event.stopPropagation()"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M10 6V0H2v6H0v2h12V6h-2zm2 8.5V10H2v4.5a3.5 3.5 0 1 0 7 0V12h2v2.5a5.5 5.5 0 1 1-11 0V10H0v4.5C0 18.64 3.36 22 7.5 22S15 18.64 15 14.5V10h-3v4.5z" transform="scale(0.8) translate(3,1.5)"/>
                  <path d="M7 2v18M3 6l4-4 4 4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" transform="translate(5,3) scale(0.7)"/>
                </svg>
              </a>
            </div>
          ))}
        </div>

        <div id="mini-player" class="hidden border-t border-border bg-charcoal px-5 py-3">
          <div class="flex items-center gap-3">
            <button id="player-play-btn" class="text-white hover:text-accent transition-colors flex-shrink-0" aria-label="Play/Pause">
              <svg id="player-play-icon" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
              <svg id="player-pause-icon" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
              </svg>
            </button>

            <div class="flex-1 min-w-0">
              <p id="player-title" class="text-xs font-semibold text-text-primary truncate"></p>
              <div id="player-progress-container" class="mt-1 h-1 bg-border rounded-full cursor-pointer group/progress">
                <div id="player-progress" class="h-full bg-accent rounded-full transition-[width] duration-150 relative" style="width: 0%">
                  <div class="absolute right-0 top-1/2 -translate-y-1/2 w-2.5 h-2.5 bg-white rounded-full opacity-0 group-hover/progress:opacity-100 transition-opacity shadow-md"></div>
                </div>
              </div>
            </div>

            <span id="player-time" class="text-[10px] text-text-muted tabular-nums flex-shrink-0">0:00 / 0:00</span>

            <div class="hidden sm:flex items-center gap-1.5">
              <button id="player-vol-btn" class="text-text-muted hover:text-white transition-colors flex-shrink-0" aria-label="Mute/Unmute">
                <svg id="vol-icon-on" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072M12 6l-4 4H4v4h4l4 4V6z"/>
                </svg>
                <svg id="vol-icon-off" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707A1 1 0 0112 5v14a1 1 0 01-1.707.707L5.586 15z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"/>
                </svg>
              </button>
              <input id="player-volume" type="range" min="0" max="1" step="0.05" value="0.8"
                     class="w-16 h-1 accent-accent bg-border rounded-full appearance-none cursor-pointer
                            [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-2.5
                            [&::-webkit-slider-thumb]:h-2.5 [&::-webkit-slider-thumb]:rounded-full
                            [&::-webkit-slider-thumb]:bg-white [&::-webkit-slider-thumb]:cursor-pointer" />
            </div>
          </div>
        </div>
      </div>

      <div id="assets-panel" class="hidden divide-y divide-border">
        <a href={withBase('assets')} class="flex items-center justify-between px-5 py-3 bg-charcoal border-b border-border text-[10px] font-bold uppercase tracking-widest text-text-secondary hover:text-text-primary transition-colors">
          Browse All Public Assets
          <span class="text-text-muted">→</span>
        </a>
        {publicAssets.length > 0 ? (
          publicAssets.map((asset) => (
            <a href={assetPath(asset.slug)} class="flex items-center justify-between gap-4 px-5 py-4 hover:bg-surface-hover transition-colors group">
              <div class="min-w-0">
                <p class="text-sm font-semibold text-text-primary truncate group-hover:text-accent transition-colors">{asset.title}</p>
                <p class="text-xs text-text-muted truncate">{asset.category} · {asset.date}</p>
                <p class="text-xs text-text-muted/80 truncate">{asset.fileName}</p>
              </div>
              <div class="flex items-center gap-3 flex-shrink-0">
                <span class="text-[9px] font-bold uppercase tracking-wider text-text-muted border border-border px-2 py-0.5 rounded-sm">
                  {asset.extension}
                </span>
                <span class="text-xs font-semibold uppercase tracking-widest text-text-secondary group-hover:text-accent transition-colors">
                  View
                </span>
              </div>
            </a>
          ))
        ) : (
          <div class="px-5 py-6 text-center">
            <p class="text-xs text-text-secondary">No public assets available yet.</p>
          </div>
        )}
      </div>

      <audio id="audio-el" preload="none"></audio>
    </div>

    <!-- Right Column: Blog / Musings -->
    <div class="surface-card rounded-sm overflow-hidden">
      <div class="flex border-b border-border">
        {['Musings', 'Process Notes'].map((tab, i) => (
          <button
            class:list={[
              'px-5 py-3 text-[10px] font-bold uppercase tracking-widest transition-colors',
              i === 0
                ? 'tab-active bg-surface'
                : 'text-text-muted hover:text-text-secondary bg-charcoal',
            ]}
          >
            {tab}
          </button>
        ))}
      </div>

      <div class="divide-y divide-border">
        <a href={withBase('musings')} class="flex items-center justify-between px-5 py-3 bg-charcoal border-b border-border text-[10px] font-bold uppercase tracking-widest text-text-secondary hover:text-text-primary transition-colors">
          Browse All Musings
          <span class="text-text-muted">→</span>
        </a>
        {posts.map(post => (
          <a href={musingPath(post.slug)} class="block px-5 py-4 hover:bg-surface-hover transition-colors group">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h4 class="text-sm font-bold text-accent group-hover:text-accent-hover transition-colors mb-1">
                  {post.title}
                </h4>
                <p class="text-xs text-text-secondary leading-relaxed line-clamp-2">
                  {post.excerpt}
                </p>
              </div>
              <span class="text-[10px] text-text-muted whitespace-nowrap pt-0.5">{post.date}</span>
            </div>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  // ── Audio Player Logic ──
  const audio = document.getElementById('audio-el') as HTMLAudioElement;
  const miniPlayer = document.getElementById('mini-player')!;
  const trackRows = document.querySelectorAll('.track-row');
  const playerPlayBtn = document.getElementById('player-play-btn')!;
  const playerPlayIcon = document.getElementById('player-play-icon')!;
  const playerPauseIcon = document.getElementById('player-pause-icon')!;
  const playerTitle = document.getElementById('player-title')!;
  const playerProgress = document.getElementById('player-progress')!;
  const playerProgressContainer = document.getElementById('player-progress-container')!;
  const playerTime = document.getElementById('player-time')!;
  const playerVolBtn = document.getElementById('player-vol-btn')!;
  const playerVolume = document.getElementById('player-volume') as HTMLInputElement;
  const volIconOn = document.getElementById('vol-icon-on')!;
  const volIconOff = document.getElementById('vol-icon-off')!;
  const tracksTabBtn = document.getElementById('tracks-tab-btn') as HTMLButtonElement;
  const assetsTabBtn = document.getElementById('assets-tab-btn') as HTMLButtonElement;
  const tracksPanel = document.getElementById('tracks-panel')!;
  const assetsPanel = document.getElementById('assets-panel')!;

  let currentIndex = -1;
  let isPlaying = false;

  function setLeftTab(tab: 'tracks' | 'assets') {
    const isTracks = tab === 'tracks';

    tracksTabBtn.className = isTracks
      ? 'px-5 py-3 text-[10px] font-bold uppercase tracking-widest transition-colors tab-active bg-surface'
      : 'px-5 py-3 text-[10px] font-bold uppercase tracking-widest transition-colors text-text-muted hover:text-text-secondary bg-charcoal';

    assetsTabBtn.className = isTracks
      ? 'px-5 py-3 text-[10px] font-bold uppercase tracking-widest transition-colors text-text-muted hover:text-text-secondary bg-charcoal'
      : 'px-5 py-3 text-[10px] font-bold uppercase tracking-widest transition-colors tab-active bg-surface';

    tracksPanel.classList.toggle('hidden', !isTracks);
    assetsPanel.classList.toggle('hidden', isTracks);
  }

  tracksTabBtn.addEventListener('click', () => setLeftTab('tracks'));
  assetsTabBtn.addEventListener('click', () => setLeftTab('assets'));

  function formatTime(sec: number): string {
    if (!isFinite(sec) || sec < 0) return '0:00';
    const m = Math.floor(sec / 60);
    const s = Math.floor(sec % 60);
    return `${m}:${s.toString().padStart(2, '0')}`;
  }

  function setActiveRow(index: number) {
    trackRows.forEach((row, i) => {
      const el = row as HTMLElement;
      if (i === index && isPlaying) {
        el.classList.add('bg-surface-hover');
        el.querySelector('.track-play-overlay')?.classList.add('!opacity-100');
        el.querySelector('.play-icon')?.classList.add('hidden');
        el.querySelector('.pause-icon')?.classList.remove('hidden');
      } else {
        el.classList.remove('bg-surface-hover');
        el.querySelector('.track-play-overlay')?.classList.remove('!opacity-100');
        el.querySelector('.play-icon')?.classList.remove('hidden');
        el.querySelector('.pause-icon')?.classList.add('hidden');
      }
    });
  }

  function updatePlayerUI() {
    if (isPlaying) {
      playerPlayIcon.classList.add('hidden');
      playerPauseIcon.classList.remove('hidden');
    } else {
      playerPlayIcon.classList.remove('hidden');
      playerPauseIcon.classList.add('hidden');
    }
    setActiveRow(currentIndex);
  }

  function playTrack(index: number) {
    const row = trackRows[index] as HTMLElement;
    if (!row) return;

    const streamUrl = row.dataset.stream;
    const title = row.dataset.title ?? 'Unknown';

    if (!streamUrl) {
      // No stream — open SoundCloud link instead
      window.open(row.dataset.href, '_blank');
      return;
    }

    if (index === currentIndex) {
      // Toggle play/pause on current track
      if (isPlaying) {
        audio.pause();
        isPlaying = false;
      } else {
        audio.play();
        isPlaying = true;
      }
    } else {
      // Switch to new track
      currentIndex = index;
      audio.src = streamUrl;
      audio.load();
      audio.play();
      isPlaying = true;

      playerTitle.textContent = title;
      miniPlayer.classList.remove('hidden');
    }

    updatePlayerUI();
  }

  // Click handlers on track rows
  trackRows.forEach((row, index) => {
    row.addEventListener('click', () => playTrack(index));
  });

  // Mini player play/pause button
  playerPlayBtn.addEventListener('click', () => {
    if (currentIndex < 0) return;
    if (isPlaying) {
      audio.pause();
      isPlaying = false;
    } else {
      audio.play();
      isPlaying = true;
    }
    updatePlayerUI();
  });

  // Progress bar updates
  audio.addEventListener('timeupdate', () => {
    if (!audio.duration) return;
    const pct = (audio.currentTime / audio.duration) * 100;
    playerProgress.style.width = `${pct}%`;
    playerTime.textContent = `${formatTime(audio.currentTime)} / ${formatTime(audio.duration)}`;
  });

  // Click to seek on progress bar
  playerProgressContainer.addEventListener('click', (e: MouseEvent) => {
    if (!audio.duration) return;
    const rect = playerProgressContainer.getBoundingClientRect();
    const pct = (e.clientX - rect.left) / rect.width;
    audio.currentTime = pct * audio.duration;
  });

  // When track ends — play next or stop
  audio.addEventListener('ended', () => {
    if (currentIndex < trackRows.length - 1) {
      playTrack(currentIndex + 1);
    } else {
      isPlaying = false;
      updatePlayerUI();
    }
  });

  // Volume controls
  audio.volume = parseFloat(playerVolume.value);

  playerVolume.addEventListener('input', () => {
    audio.volume = parseFloat(playerVolume.value);
    audio.muted = false;
    volIconOn.classList.remove('hidden');
    volIconOff.classList.add('hidden');
  });

  playerVolBtn.addEventListener('click', () => {
    audio.muted = !audio.muted;
    if (audio.muted) {
      volIconOn.classList.add('hidden');
      volIconOff.classList.remove('hidden');
    } else {
      volIconOn.classList.remove('hidden');
      volIconOff.classList.add('hidden');
    }
  });
</script>