---
/**
 * Header — Top navigation bar
 * Mirrors the PS.com top nav: logo left, nav links center, search right
 */
import { withBase } from '../lib/paths';
---

<header class="sticky top-0 z-50 bg-obsidian/95 backdrop-blur-sm border-b border-border">
  <!-- Top bar: branding + nav + search -->
  <div class="max-w-[var(--width-content)] mx-auto flex items-center justify-between px-4 h-14">

    <!-- Logo / Brand -->
    <a href={withBase()} class="flex items-center gap-2 group">
      <div class="w-8 h-8 rounded-full bg-accent flex items-center justify-center text-white font-display font-bold text-sm
                  group-hover:shadow-[0_0_12px_rgba(230,0,18,0.5)] transition-shadow">
        BB
      </div>
      <span class="font-display text-lg uppercase tracking-wider text-text-primary">
        Boink Brands
      </span>
    </a>

    <!-- Navigation -->
    <nav class="hidden md:flex items-center gap-1">
      <!-- Social Media Icons -->
      <a href="https://x.com" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)"
         class="w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-primary transition-colors rounded-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="https://store.steampowered.com" target="_blank" rel="noopener noreferrer" aria-label="Steam"
         class="w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-primary transition-colors rounded-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658a3.387 3.387 0 0 1 1.912-.59c.064 0 .128.003.19.008l2.861-4.142V8.91a4.528 4.528 0 0 1 4.524-4.524c2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396a3.406 3.406 0 0 1-3.327-2.725L.436 14.71C1.862 19.972 6.486 24 11.979 24c6.627 0 12-5.373 12-12S18.606 0 11.979 0zM7.54 18.21l-1.473-.61a2.539 2.539 0 0 0 4.641-.597 2.548 2.548 0 0 0-1.27-2.763 2.546 2.546 0 0 0-1.881-.271l1.523.63a1.88 1.88 0 0 1-1.44 3.472l-.1-.041v-.001l.001.001-.001-.001zm8.4-5.695a3.016 3.016 0 0 0 3.015-3.012 3.016 3.016 0 0 0-3.015-3.015 3.02 3.02 0 0 0-3.015 3.015 3.017 3.017 0 0 0 3.015 3.012zm-2.263-3.014a2.265 2.265 0 0 1 2.262-2.262 2.265 2.265 0 0 1 2.263 2.262 2.265 2.265 0 0 1-2.263 2.263 2.265 2.265 0 0 1-2.262-2.263z"/>
        </svg>
      </a>
      <a href="https://discord.gg" target="_blank" rel="noopener noreferrer" aria-label="Discord"
         class="w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-primary transition-colors rounded-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
        </svg>
      </a>
      <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" aria-label="YouTube"
         class="w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-primary transition-colors rounded-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>

      <!-- Divider -->
      <span class="w-px h-4 bg-border mx-2"></span>

      <!-- About link -->
      <a href="#about"
         class="px-4 py-2 text-xs font-semibold uppercase tracking-widest text-text-secondary
                hover:text-text-primary hover:bg-surface transition-all duration-200 rounded-sm">
        About
      </a>
    </nav>

    <!-- Search / CTA -->
    <div class="flex items-center gap-3">
      <button
        aria-label="Search"
        class="w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-primary transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>

      <!-- Mobile hamburger -->
      <button
        aria-label="Menu"
        class="md:hidden w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-primary transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>
