---
/**
 * Header — Top navigation bar
 * Mirrors the PS.com top nav: logo left, nav links center, search right
 */
import { withBase } from '../lib/paths';
---

<header class="sticky top-0 z-50 bg-obsidian/95 backdrop-blur-sm border-b border-border">
  <!-- Top bar: branding + nav + search -->
  <div class="max-w-[var(--width-content)] mx-auto flex items-center justify-between px-4 h-14">

    <!-- Logo / Brand -->
    <a href={withBase()} class="flex items-center gap-2 group">
      <div class="w-8 h-8 rounded-full bg-accent flex items-center justify-center text-white font-display font-bold text-sm
                  group-hover:shadow-[0_0_12px_rgba(230,0,18,0.5)] transition-shadow">
        BB
      </div>
      <span class="font-display text-lg uppercase tracking-wider text-text-primary">
        Boink Brands
      </span>
    </a>

    <!-- Navigation -->
    <nav class="hidden md:flex items-center gap-1">
      <!-- Social Media Icons -->
      <a href="https://x.com/boinkbranded" target="_blank" rel="noopener noreferrer" aria-label="X.com"
         class="w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-primary transition-colors rounded-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="https://github.com/boinktm" target="_blank" rel="noopener noreferrer" aria-label="GitHub"
         class="w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-primary transition-colors rounded-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .297a12 12 0 0 0-3.79 23.39c.6.112.82-.26.82-.577v-2.256c-3.338.727-4.042-1.416-4.042-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.084 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.776.418-1.304.76-1.604-2.665-.303-5.467-1.334-5.467-5.932 0-1.31.47-2.38 1.236-3.22-.124-.303-.536-1.523.118-3.176 0 0 1.008-.322 3.3 1.23a11.5 11.5 0 0 1 6.004 0c2.292-1.552 3.3-1.23 3.3-1.23.654 1.653.242 2.873.118 3.176.767.84 1.236 1.91 1.236 3.22 0 4.61-2.807 5.625-5.48 5.922.43.372.814 1.103.814 2.223v3.293c0 .319.218.694.825.576A12.002 12.002 0 0 0 12 .297"/>
        </svg>
      </a>
      <a href="https://www.youtube.com/@BoinkBrands" target="_blank" rel="noopener noreferrer" aria-label="YouTube"
         class="w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-primary transition-colors rounded-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>

      <!-- Divider -->
      <span class="w-px h-4 bg-border mx-2"></span>

      <!-- About link -->
      <a href="#about"
         class="px-4 py-2 text-xs font-semibold uppercase tracking-widest text-text-secondary
                hover:text-text-primary hover:bg-surface transition-all duration-200 rounded-sm">
        About
      </a>
    </nav>

    <!-- Search / CTA -->
    <div class="flex items-center gap-3">
      <button
        aria-label="Search"
        class="w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-primary transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>

      <!-- Mobile hamburger -->
      <button
        aria-label="Menu"
        class="md:hidden w-8 h-8 flex items-center justify-center text-text-muted hover:text-text-primary transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>
