---
/**
 * ImageLightbox — Full-screen image viewer with navigation
 * Triggered by .lightbox-trigger buttons on the MappingGallery
 * All logic is client-side vanilla JS — no framework needed.
 */
---


<!-- Lightbox overlay (hidden by default) -->
<div id="lightbox-overlay" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="lightbox-backdrop" class="absolute inset-0 bg-void/95 backdrop-blur-sm"></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center justify-center h-full p-4 md:p-8">
    <!-- Header bar -->
    <div class="w-full max-w-5xl flex items-center justify-between mb-4">
      <div>
        <h3 id="lightbox-title" class="font-display text-lg uppercase text-text-primary tracking-wider"></h3>
        <p id="lightbox-counter" class="text-[10px] uppercase tracking-widest text-text-muted mt-0.5"></p>
      </div>
      <button id="lightbox-close"
              class="w-10 h-10 flex items-center justify-center text-text-muted hover:text-text-primary
                     border border-border hover:border-border-light rounded-sm transition-all"
              aria-label="Close lightbox">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Image area -->
    <div class="relative flex-1 w-full max-w-5xl flex items-center justify-center min-h-0">
      <!-- Prev -->
      <button id="lightbox-prev"
              class="absolute left-0 z-20 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center
                     bg-surface/80 border border-border hover:border-border-light rounded-sm
                     text-text-muted hover:text-text-primary transition-all -translate-x-1/2 md:translate-x-0"
              aria-label="Previous image">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <!-- Image -->
      <img id="lightbox-image" src="" alt=""
           class="max-h-full max-w-full object-contain rounded-sm border border-border shadow-2xl transition-opacity duration-200" />

      <!-- Next -->
      <button id="lightbox-next"
              class="absolute right-0 z-20 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center
                     bg-surface/80 border border-border hover:border-border-light rounded-sm
                     text-text-muted hover:text-text-primary transition-all translate-x-1/2 md:translate-x-0"
              aria-label="Next image">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>

    <!-- Thumbnail strip -->
    <div id="lightbox-thumbs" class="flex items-center gap-2 mt-4 overflow-x-auto max-w-5xl pb-1"></div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const overlay   = document.getElementById('lightbox-overlay')!;
    const backdrop  = document.getElementById('lightbox-backdrop')!;
    const image     = document.getElementById('lightbox-image') as HTMLImageElement;
    const title     = document.getElementById('lightbox-title')!;
    const counter   = document.getElementById('lightbox-counter')!;
    const closeBtn  = document.getElementById('lightbox-close')!;
    const prevBtn   = document.getElementById('lightbox-prev')!;
    const nextBtn   = document.getElementById('lightbox-next')!;
    const thumbStrip = document.getElementById('lightbox-thumbs')!;

    let images: string[] = [];
    let currentIndex = 0;

    function show(idx: number) {
      currentIndex = Math.max(0, Math.min(idx, images.length - 1));
      image.style.opacity = '0';
      setTimeout(() => {
        image.src = images[currentIndex];
        image.alt = `Image ${currentIndex + 1}`;
        image.style.opacity = '1';
      }, 100);
      counter.textContent = `${currentIndex + 1} / ${images.length}`;

      // Update thumbnail highlights
      thumbStrip.querySelectorAll('img').forEach((thumb, i) => {
        thumb.classList.toggle('border-accent', i === currentIndex);
        thumb.classList.toggle('border-border', i !== currentIndex);
        thumb.classList.toggle('opacity-100', i === currentIndex);
        thumb.classList.toggle('opacity-50', i !== currentIndex);
      });
    }

    function open(imageList: string[], projectTitle: string, startIdx = 0) {
      images = imageList;
      title.textContent = projectTitle;
      overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';

      // Build thumbnail strip
      thumbStrip.innerHTML = '';
      imageList.forEach((src, i) => {
        const thumb = document.createElement('img');
        thumb.src = src;
        thumb.alt = `Thumbnail ${i + 1}`;
        thumb.className = 'w-14 h-14 md:w-16 md:h-10 object-cover rounded-sm border cursor-pointer transition-all hover:opacity-80 flex-shrink-0';
        thumb.addEventListener('click', () => show(i));
        thumbStrip.appendChild(thumb);
      });

      show(startIdx);
    }

    function close() {
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
      image.src = '';
    }

    // Attach triggers
    document.querySelectorAll('.lightbox-trigger').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const el = btn as HTMLElement;
        const imgs = JSON.parse(el.dataset.images || '[]');
        const name = el.dataset.title || '';
        const startIdx = parseInt(el.dataset.start || '0', 10);
        if (imgs.length) open(imgs, name, startIdx);
      });
    });

    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    prevBtn.addEventListener('click', () => show(currentIndex - 1));
    nextBtn.addEventListener('click', () => show(currentIndex + 1));

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (overlay.classList.contains('hidden')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(currentIndex - 1);
      if (e.key === 'ArrowRight') show(currentIndex + 1);
    });
  });
</script>
