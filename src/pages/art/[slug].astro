---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import SubNav from '../../components/SubNav.astro';
import ImageLightbox from '../../components/ImageLightbox.astro';
import Footer from '../../components/Footer.astro';
import { artPath, withBase } from '../../lib/paths';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

export const getStaticPaths = (async () => {
  const entries = await getCollection('art');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { entry } = Astro.props as Props;
const piece = { slug: entry.id, ...entry.data };
const { Content } = await render(entry);
const hasPieceNotes = typeof entry.body === 'string' && entry.body.trim().length > 0;

const isDirectVideo = (url: string) => /\.(mp4|webm|ogg)(\?.*)?$/i.test(url);
const toEmbedUrl = (url: string) => {
  if (url.includes('youtube.com/watch')) {
    const parsed = new URL(url);
    const id = parsed.searchParams.get('v');
    return id ? `https://www.youtube.com/embed/${id}` : url;
  }
  if (url.includes('youtu.be/')) {
    const id = url.split('youtu.be/')[1]?.split(/[?&#]/)[0];
    return id ? `https://www.youtube.com/embed/${id}` : url;
  }
  if (url.includes('youtube.com/shorts/')) {
    const id = url.split('youtube.com/shorts/')[1]?.split(/[?&#]/)[0];
    return id ? `https://www.youtube.com/embed/${id}` : url;
  }
  return url;
};

const normalizedVideos = piece.videos.map(url => ({
  source: url,
  embedUrl: toEmbedUrl(url),
  isDirect: isDirectVideo(url),
}));

const galleryImages = piece.images.length > 0
  ? piece.images
  : (piece.fullres ? [piece.fullres] : []);
const hasSingleGalleryImage = galleryImages.length === 1;
const galleryImageUrls = galleryImages.map(img => withBase(img));

const allEntries = await getCollection('art');
const otherPieces = allEntries
  .filter(e => e.id !== entry.id)
  .slice(0, 4)
  .map(e => ({ slug: e.id, ...e.data }));
---

<Layout title={`${piece.title} — 3D Art — Boink Brands`} description={piece.tagline}>
  <Header />
  <SubNav activeTab="3D Art" />

  <section class="relative overflow-hidden bg-void">
    <img
      src={withBase(piece.thumbnail)}
      alt={piece.title}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-void via-void/80 to-charcoal/50"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-void/70 to-transparent"></div>

    <div class="relative max-w-[var(--width-content)] mx-auto px-4 py-20 md:py-28">
      <nav class="flex items-center gap-2 text-[10px] uppercase tracking-widest text-text-muted mb-6">
        <a href={withBase()} class="hover:text-text-primary transition-colors">Home</a>
        <span>/</span>
        <a href={withBase('art')} class="hover:text-text-primary transition-colors">3D Art</a>
        <span>/</span>
        <span class="text-text-secondary">{piece.title}</span>
      </nav>

      <div class="flex items-center gap-2 mb-3">
        {piece.featured && (
          <span class="text-[9px] font-bold uppercase tracking-wider bg-accent/20 text-accent px-2 py-0.5 rounded-sm">
            Featured
          </span>
        )}
        <span class="text-[9px] font-bold uppercase tracking-wider text-text-muted">
          {piece.medium}
        </span>
        <span class="text-[9px] text-text-muted">·</span>
        <span class="text-[9px] uppercase tracking-wider text-text-muted">{piece.date}</span>
      </div>

      {piece.videos.length > 0 && (
        <div class="mb-3">
          <span class="text-[9px] font-bold uppercase tracking-wider bg-accent/20 text-accent px-2 py-0.5 rounded-sm">
            {piece.videos.length} video{piece.videos.length === 1 ? '' : 's'}
          </span>
        </div>
      )}

      <h1 class="font-display text-4xl md:text-6xl lg:text-7xl uppercase leading-none text-text-primary mb-4">
        {piece.title}
      </h1>
      <p class="text-text-secondary text-sm md:text-base max-w-2xl">{piece.tagline}</p>

      <div class="flex items-center gap-4 mt-6 flex-wrap">
        {galleryImages.length > 0 && (
          <button
            class="lightbox-trigger px-6 py-3 bg-accent hover:bg-accent-hover text-white text-xs font-bold uppercase tracking-widest
                   transition-all duration-200 rounded-sm hover:shadow-[0_0_20px_rgba(230,0,18,0.3)]"
            data-images={JSON.stringify(galleryImageUrls)}
            data-title={piece.title}
            data-start="0"
          >
            {hasSingleGalleryImage ? 'View Image' : 'Open Gallery'}
          </button>
        )}
        {piece.externalUrl && (
          <a href={piece.externalUrl}
             target="_blank"
             rel="noopener noreferrer"
             class="px-6 py-3 border border-border hover:border-border-light text-text-secondary hover:text-text-primary
                    text-xs font-bold uppercase tracking-widest transition-all duration-200 rounded-sm">
            External Link
          </a>
        )}
        <a href={withBase('art')}
           class="px-6 py-3 border border-border hover:border-border-light text-text-secondary hover:text-text-primary
                  text-xs font-bold uppercase tracking-widest transition-all duration-200 rounded-sm">
          &larr; Back to Gallery
        </a>
        {normalizedVideos.length > 0 && (
          <a
            href="#videos"
            class="px-6 py-3 border border-border hover:border-border-light text-text-secondary hover:text-text-primary
                   text-xs font-bold uppercase tracking-widest transition-all duration-200 rounded-sm"
          >
            Jump to Videos
          </a>
        )}
      </div>

      <div class="flex flex-wrap gap-2 mt-6">
        {piece.tags.map(tag => (
          <span class="text-[9px] font-semibold uppercase tracking-wider text-text-muted border border-border px-2 py-0.5 rounded-sm">
            {tag}
          </span>
        ))}
      </div>
    </div>
    <div class="chrome-divider"></div>
  </section>

  <section class="bg-obsidian py-10">
    <div class="max-w-[var(--width-content)] mx-auto px-4 grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-8">
        {galleryImages.length > 0 && (
          <div class="surface-card rounded-sm p-6 md:p-8">
            <div class="flex items-center justify-between mb-4">
              <h2 class="font-display text-lg uppercase tracking-wider text-text-primary">
                {hasSingleGalleryImage ? 'Featured Render' : 'Gallery'}
              </h2>
              <span class="text-[10px] uppercase tracking-widest text-text-muted">
                {galleryImages.length} image{galleryImages.length === 1 ? '' : 's'}
              </span>
            </div>
            <div class="chrome-divider mb-5"></div>
            {hasSingleGalleryImage ? (
              <button
                class="lightbox-trigger relative aspect-[16/10] md:aspect-[21/9] overflow-hidden rounded-sm border border-border
                       hover:border-border-light transition-all group cursor-pointer w-full"
                data-images={JSON.stringify(galleryImageUrls)}
                data-title={piece.title}
                data-start="0"
              >
                <img
                  src={galleryImageUrls[0]}
                  alt={`${piece.title} featured render`}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-void/0 group-hover:bg-void/30 transition-colors flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg"
                       class="w-10 h-10 text-white opacity-0 group-hover:opacity-80 transition-opacity"
                       fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                  </svg>
                </div>
              </button>
            ) : (
              <div class="grid grid-cols-2 gap-3">
                {galleryImages.map((img, i) => (
                <button
                  class="lightbox-trigger relative aspect-[16/9] overflow-hidden rounded-sm border border-border
                         hover:border-border-light transition-all group cursor-pointer"
                  data-images={JSON.stringify(galleryImageUrls)}
                  data-title={piece.title}
                  data-start={i}
                >
                  <img src={withBase(img)} alt={`${piece.title} image ${i + 1}`}
                       class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                       loading="lazy" />
                  <div class="absolute inset-0 bg-void/0 group-hover:bg-void/30 transition-colors flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         class="w-8 h-8 text-white opacity-0 group-hover:opacity-80 transition-opacity"
                         fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                    </svg>
                  </div>
                  </button>
                  ))}
                </div>
              )}
          </div>
        )}

        {normalizedVideos.length > 0 && (
          <div id="videos" class="surface-card rounded-sm p-6 md:p-8">
            <div class="flex items-center justify-between mb-4">
              <h2 class="font-display text-lg uppercase tracking-wider text-text-primary">Videos</h2>
              <span class="text-[10px] uppercase tracking-widest text-text-muted">{normalizedVideos.length} videos</span>
            </div>
            <div class="chrome-divider mb-5"></div>
            <div class="space-y-4">
              {normalizedVideos.map(video => (
                <div class="aspect-video rounded-sm overflow-hidden border border-border bg-charcoal">
                  {video.isDirect ? (
                    <video class="w-full h-full" controls preload="metadata" playsinline>
                      <source src={withBase(video.source)} />
                    </video>
                  ) : (
                    <iframe
                      src={video.embedUrl}
                      class="w-full h-full"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    ></iframe>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        {hasPieceNotes && (
          <div class="surface-card rounded-sm p-6 md:p-8">
            <h2 class="font-display text-lg uppercase tracking-wider text-text-primary mb-4">Piece Notes</h2>
            <div class="chrome-divider mb-5"></div>
            <div class="space-y-4 text-sm text-text-secondary leading-relaxed [&>p]:mb-4 [&>h2]:font-display [&>h2]:text-text-primary [&>h2]:uppercase [&>h2]:mt-6 [&>h2]:mb-2 [&>h3]:font-display [&>h3]:text-text-primary [&>h3]:mt-4 [&>h3]:mb-2 [&>ul]:list-disc [&>ul]:pl-5 [&>ol]:list-decimal [&>ol]:pl-5 [&>a]:text-accent [&>a:hover]:text-accent-hover">
              <Content />
            </div>
          </div>
        )}
      </div>

      <div class="space-y-4">
        <div class="surface-card rounded-sm p-6">
          <h3 class="font-display text-sm uppercase tracking-wider text-text-primary mb-4">Piece Info</h3>
          <div class="chrome-divider mb-4"></div>
          <dl class="space-y-3">
            <div>
              <dt class="text-[9px] uppercase tracking-widest text-text-muted font-bold">Medium</dt>
              <dd class="text-sm text-text-primary mt-0.5">{piece.medium}</dd>
            </div>
            <div>
              <dt class="text-[9px] uppercase tracking-widest text-text-muted font-bold">Status</dt>
              <dd class="text-sm text-text-primary mt-0.5">{piece.status}</dd>
            </div>
            <div>
              <dt class="text-[9px] uppercase tracking-widest text-text-muted font-bold">Date</dt>
              <dd class="text-sm text-text-primary mt-0.5">{piece.date}</dd>
            </div>
            {piece.software.length > 0 && (
              <div>
                <dt class="text-[9px] uppercase tracking-widest text-text-muted font-bold">Software</dt>
                <dd class="text-sm text-text-primary mt-0.5">{piece.software.join(', ')}</dd>
              </div>
            )}
          </dl>
        </div>

        {otherPieces.length > 0 && (
          <div class="surface-card rounded-sm p-6">
            <h3 class="font-display text-sm uppercase tracking-wider text-text-primary mb-4">Other Pieces</h3>
            <div class="chrome-divider mb-4"></div>
            <div class="space-y-3">
              {otherPieces.map(other => (
                <a href={artPath(other.slug)} class="flex items-center gap-3 group">
                  <img src={withBase(other.thumbnail)} alt={other.title}
                       class="w-14 h-10 object-cover rounded-sm border border-border group-hover:border-border-light transition-colors flex-shrink-0"
                       loading="lazy" />
                  <div class="min-w-0">
                    <p class="text-xs font-semibold text-text-primary truncate group-hover:text-accent transition-colors">
                      {other.title}
                    </p>
                    <p class="text-[9px] text-text-muted">{other.date}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <ImageLightbox />
  <Footer />
</Layout>