---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import SubNav from '../../components/SubNav.astro';
import ImageLightbox from '../../components/ImageLightbox.astro';
import Footer from '../../components/Footer.astro';
import { artPath, withBase } from '../../lib/paths';
import { getCollection } from 'astro:content';

const entries = await getCollection('art');
const works = entries.map(entry => ({
  slug: entry.id,
  ...entry.data,
}));

const featuredWork = works.find(work => work.featured) ?? works[0] ?? null;
const restWorks = featuredWork
  ? works.filter(work => work.slug !== featuredWork.slug)
  : [];

const isDirectVideo = (url: string) => /\.(mp4|webm|ogg)(\?.*)?$/i.test(url);
const toEmbedUrl = (url: string) => {
  if (url.includes('youtube.com/watch')) {
    const parsed = new URL(url);
    const id = parsed.searchParams.get('v');
    return id ? `https://www.youtube.com/embed/${id}` : url;
  }
  if (url.includes('youtu.be/')) {
    const id = url.split('youtu.be/')[1]?.split(/[?&#]/)[0];
    return id ? `https://www.youtube.com/embed/${id}` : url;
  }
  if (url.includes('youtube.com/shorts/')) {
    const id = url.split('youtube.com/shorts/')[1]?.split(/[?&#]/)[0];
    return id ? `https://www.youtube.com/embed/${id}` : url;
  }
  return url;
};

const isVideoOnlyWork = (work: (typeof works)[number]) => work.videos.length > 0 && work.images.length === 0 && !work.fullres;
const getPrimaryVideo = (work: (typeof works)[number]) => work.videos[0] ?? '';
const getInlineVideoSource = (work: (typeof works)[number]) => {
  const source = getPrimaryVideo(work);
  return isDirectVideo(source) ? withBase(source) : source;
};
const getInlineVideoEmbed = (work: (typeof works)[number]) => toEmbedUrl(getPrimaryVideo(work));
---

<Layout title="3D Art — Boink Brands" description="A dedicated gallery of 3D art studies, environment work, and character-focused experiments from Boink Brands.">
  <Header />
  <SubNav activeTab="3D Art" />

  <section class="bg-void relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(230,0,18,0.07)_0%,transparent_70%)]"></div>
    <div class="relative max-w-[var(--width-content)] mx-auto px-4 py-16 md:py-20 text-center">
      <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-accent mb-3">Visual Lab</p>
      <h1 class="font-display text-4xl md:text-6xl uppercase leading-none tracking-tight mb-4">
        <span class="text-gradient">3D</span>
        <br />
        <span class="text-text-primary">Art</span>
      </h1>
      <p class="text-text-secondary text-sm md:text-base max-w-lg mx-auto leading-relaxed mb-8">
        A focused gallery of form, lighting, and material studies. This page is dedicated to current 3D experiments and finished visual pieces.
      </p>

      <div class="flex items-center justify-center gap-3 flex-wrap">
        {featuredWork && (
          <a
            href={artPath(featuredWork.slug)}
            class="px-6 py-3 bg-accent hover:bg-accent-hover text-white text-xs font-bold uppercase tracking-widest
                  transition-all duration-200 rounded-sm hover:shadow-[0_0_20px_rgba(230,0,18,0.3)]"
          >
            View Featured Piece
          </a>
        )}
        <a
          href={withBase('mapping')}
          class="px-6 py-3 border border-border hover:border-border-light text-text-secondary hover:text-text-primary
                 text-xs font-bold uppercase tracking-widest transition-all duration-200 rounded-sm"
        >
          View Mapping Work
        </a>
      </div>
    </div>
    <div class="chrome-divider"></div>
  </section>

  <section class="bg-obsidian py-8">
    <div class="max-w-[var(--width-content)] mx-auto px-4 space-y-4">
      {featuredWork ? (
        <>
          <article class="surface-card rounded-sm overflow-hidden">
            <div class="relative aspect-[21/9] md:aspect-[3/1] overflow-hidden">
              {isVideoOnlyWork(featuredWork) ? (
                <>
                  <img
                    src={withBase(featuredWork.thumbnail)}
                    alt={featuredWork.title}
                    class="inline-video-poster absolute inset-0 w-full h-full object-cover"
                    loading="eager"
                  />
                  <div class="inline-video-overlay absolute inset-0 bg-gradient-to-t from-void via-void/70 to-transparent"></div>
                  <div class="inline-video-overlay absolute inset-0 bg-gradient-to-r from-void/70 to-transparent"></div>
                  <div class="inline-video-player hidden absolute inset-0 z-[5]"></div>
                  <button
                    type="button"
                    class="inline-video-trigger absolute inset-0 z-[15] flex items-center justify-center"
                    data-video-source={getInlineVideoSource(featuredWork)}
                    data-video-embed={getInlineVideoEmbed(featuredWork)}
                    data-video-direct={String(isDirectVideo(getPrimaryVideo(featuredWork)))}
                    aria-label={`Play ${featuredWork.title}`}
                  >
                    <span class="w-12 h-12 rounded-full bg-void/70 border border-border-light text-text-primary flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M8 5v14l11-7z"></path>
                      </svg>
                    </span>
                  </button>
                </>
              ) : (
                <>
                  <a href={artPath(featuredWork.slug)} class="absolute inset-0">
                    <img
                      src={withBase(featuredWork.thumbnail)}
                      alt={featuredWork.title}
                      class="absolute inset-0 w-full h-full object-cover"
                      loading="eager"
                    />
                  </a>
                  <div class="absolute inset-0 bg-gradient-to-t from-void via-void/70 to-transparent"></div>
                  <div class="absolute inset-0 bg-gradient-to-r from-void/70 to-transparent"></div>
                </>
              )}

              <div class="relative h-full z-10 p-6 md:p-8 flex flex-col justify-end">
                <div class="flex items-center gap-2 mb-2 flex-wrap">
                  <span class="text-[9px] font-bold uppercase tracking-wider bg-accent/20 text-accent px-2 py-0.5 rounded-sm">
                    Featured
                  </span>
                  {featuredWork.videos.length > 0 && (
                    <span class="text-[9px] font-bold uppercase tracking-wider bg-accent/10 text-accent px-2 py-0.5 rounded-sm">
                      {featuredWork.videos.length} video{featuredWork.videos.length === 1 ? '' : 's'}
                    </span>
                  )}
                  <span class="text-[9px] font-bold uppercase tracking-wider text-text-muted border border-border px-2 py-0.5 rounded-sm">
                    {featuredWork.status}
                  </span>
                  <span class="text-[9px] font-bold uppercase tracking-wider text-text-muted border border-border px-2 py-0.5 rounded-sm">
                    {featuredWork.date}
                  </span>
                </div>
                <h2 class="font-display text-3xl md:text-5xl uppercase text-text-primary leading-none mb-2">
                  {featuredWork.title}
                </h2>
                <p class="text-xs text-text-secondary mb-2 uppercase tracking-[0.14em]">{featuredWork.medium}</p>
                <p class="text-sm text-text-secondary max-w-2xl leading-relaxed">{featuredWork.tagline}</p>
                <div class="mt-3 flex items-center gap-3 flex-wrap">
                  <a href={artPath(featuredWork.slug)} class="text-xs font-semibold uppercase tracking-widest text-text-secondary hover:text-accent transition-colors flex items-center gap-1">
                    View Piece
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                  {((featuredWork.images.length > 0) || Boolean(featuredWork.fullres)) && (
                    <button
                      class="lightbox-trigger text-xs text-text-muted hover:text-accent transition-colors flex items-center gap-1"
                      data-images={JSON.stringify((featuredWork.images.length > 0 ? featuredWork.images : [featuredWork.fullres]).map(img => withBase(img)))}
                      data-title={featuredWork.title}
                    >
                      Open Gallery
                    </button>
                  )}
                  {featuredWork.videos.length > 0 && (
                    <a
                      href={`${artPath(featuredWork.slug)}#videos`}
                      class="text-xs text-text-muted hover:text-accent transition-colors"
                    >
                      Watch Videos
                    </a>
                  )}
                </div>
                {featuredWork.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-3">
                    {featuredWork.tags.map(tag => (
                      <span class="text-[9px] font-semibold uppercase tracking-wider text-text-muted border border-border px-2 py-0.5 rounded-sm">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </article>

          {restWorks.length > 0 && (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {restWorks.map(work => (
                <article class="surface-card rounded-sm overflow-hidden group">
                  <div class="relative aspect-[16/9] overflow-hidden">
                    {isVideoOnlyWork(work) ? (
                      <>
                        <img
                          src={withBase(work.thumbnail)}
                          alt={work.title}
                          class="inline-video-poster w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                          loading="lazy"
                        />
                        <div class="inline-video-overlay absolute inset-0 bg-gradient-to-t from-void/80 to-transparent"></div>
                        <div class="inline-video-player hidden absolute inset-0 z-20"></div>
                        <button
                          type="button"
                          class="inline-video-trigger absolute inset-0 z-30 flex items-center justify-center"
                          data-video-source={getInlineVideoSource(work)}
                          data-video-embed={getInlineVideoEmbed(work)}
                          data-video-direct={String(isDirectVideo(getPrimaryVideo(work)))}
                          aria-label={`Play ${work.title}`}
                        >
                          <span class="w-12 h-12 rounded-full bg-void/70 border border-border-light text-text-primary flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                              <path d="M8 5v14l11-7z"></path>
                            </svg>
                          </span>
                        </button>
                      </>
                    ) : (
                      <>
                        <a href={artPath(work.slug)} class="absolute inset-0 z-10" aria-label={`View ${work.title}`}></a>
                        <img
                          src={withBase(work.thumbnail)}
                          alt={work.title}
                          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                          loading="lazy"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-void/80 to-transparent"></div>
                      </>
                    )}
                  </div>

                  <div class="p-5">
                    <div class="flex items-center justify-between gap-3 mb-2">
                      <h3 class="font-display text-xl uppercase text-text-primary leading-tight">{work.title}</h3>
                      <div class="flex items-center gap-1.5">
                        {work.videos.length > 0 && (
                          <span class="text-[9px] font-bold uppercase tracking-wider bg-accent/10 text-accent px-2 py-0.5 rounded-sm whitespace-nowrap">
                            {work.videos.length} video{work.videos.length === 1 ? '' : 's'}
                          </span>
                        )}
                        <span class="text-[9px] font-bold uppercase tracking-wider text-text-muted border border-border px-2 py-0.5 rounded-sm whitespace-nowrap">
                          {work.status}
                        </span>
                      </div>
                    </div>
                    <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-text-muted mb-1">{work.medium}</p>
                    <p class="text-[10px] uppercase tracking-wider text-text-muted mb-2">{work.date}</p>
                    <p class="text-xs text-text-secondary leading-relaxed">{work.tagline}</p>
                    <div class="mt-3 flex items-center gap-3 flex-wrap relative z-20">
                      <a href={artPath(work.slug)} class="text-xs font-semibold uppercase tracking-widest text-text-secondary hover:text-accent transition-colors flex items-center gap-1">
                        View Piece
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                        </svg>
                      </a>
                      {((work.images.length > 0) || Boolean(work.fullres)) && (
                        <button
                          class="lightbox-trigger text-xs text-text-muted hover:text-accent transition-colors"
                          data-images={JSON.stringify((work.images.length > 0 ? work.images : [work.fullres]).map(img => withBase(img)))}
                          data-title={work.title}
                          onclick="event.preventDefault(); event.stopPropagation();"
                        >
                          Open Gallery
                        </button>
                      )}
                      {work.videos.length > 0 && (
                        <a
                          href={`${artPath(work.slug)}#videos`}
                          class="text-xs text-text-muted hover:text-accent transition-colors"
                        >
                          Watch Videos
                        </a>
                      )}
                    </div>
                    {work.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mt-3">
                        {work.tags.map(tag => (
                          <span class="text-[8px] font-semibold uppercase tracking-wider text-text-muted border border-border px-1.5 py-0.5 rounded-sm">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </article>
              ))}
            </div>
          )}
        </>
      ) : (
        <article class="surface-card rounded-sm p-8 text-center">
          <h2 class="font-display text-2xl uppercase text-text-primary mb-2">Gallery Coming Online</h2>
          <p class="text-text-secondary text-sm">No art entries found yet. Add markdown files in <span class="text-text-primary">src/content/art</span> to populate this page.</p>
        </article>
      )}
    </div>
  </section>

  <ImageLightbox />
  <script>
    const inlineVideoTriggers = document.querySelectorAll('.inline-video-trigger');

    inlineVideoTriggers.forEach((trigger) => {
      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();

        const card = trigger.closest('.relative');
        const player = card?.querySelector('.inline-video-player');
        if (!card || !player || player.childElementCount > 0) {
          return;
        }

        const source = trigger.getAttribute('data-video-source') || '';
        const embed = trigger.getAttribute('data-video-embed') || source;
        const isDirect = trigger.getAttribute('data-video-direct') === 'true';

        if (!source) {
          return;
        }

        if (isDirect) {
          const video = document.createElement('video');
          video.className = 'w-full h-full object-cover';
          video.controls = true;
          video.autoplay = true;
          video.playsInline = true;
          video.preload = 'metadata';

          const sourceEl = document.createElement('source');
          sourceEl.src = source;
          video.appendChild(sourceEl);
          player.appendChild(video);
        } else {
          const iframe = document.createElement('iframe');
          const autoplaySeparator = embed.includes('?') ? '&' : '?';
          iframe.src = `${embed}${autoplaySeparator}autoplay=1`;
          iframe.className = 'w-full h-full';
          iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
          iframe.setAttribute('allowfullscreen', '');
          player.appendChild(iframe);
        }

        player.classList.remove('hidden');
        card.querySelectorAll('.inline-video-poster, .inline-video-overlay, .inline-video-trigger').forEach((element) => {
          element.classList.add('hidden');
        });
      });
    });
  </script>
  <Footer />
</Layout>