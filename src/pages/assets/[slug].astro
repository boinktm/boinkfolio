---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import SubNav from '../../components/SubNav.astro';
import Footer from '../../components/Footer.astro';
import { artPath, assetPath, withBase } from '../../lib/paths';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

export const getStaticPaths = (async () => {
  const entries = await getCollection('assets');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { entry } = Astro.props as Props;
const asset = { slug: entry.id, ...entry.data };
const { Content } = await render(entry);

const isImage = /\.(png|jpg|jpeg|webp|gif|avif)$/i.test(asset.filePath);
const displayImage = asset.previewImage ?? (isImage ? asset.filePath : null);

const allAssets = await getCollection('assets');
const related = allAssets
  .filter(a => a.id !== entry.id && a.data.isPublic)
  .slice(0, 4)
  .map(a => ({ slug: a.id, ...a.data }));
---

<Layout title={`${asset.title} — Public Assets — Boink Brands`} description={asset.summary}>
  <Header />
  <SubNav activeTab="3D Art" />

  <section class="relative overflow-hidden bg-void">
    {displayImage ? (
      <img src={withBase(displayImage)} alt={asset.title} class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-charcoal via-obsidian to-void"></div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-void via-void/80 to-charcoal/50"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-void/70 to-transparent"></div>

    <div class="relative max-w-[var(--width-content)] mx-auto px-4 py-20 md:py-28">
      <nav class="flex items-center gap-2 text-[10px] uppercase tracking-widest text-text-muted mb-6">
        <a href={withBase()} class="hover:text-text-primary transition-colors">Home</a>
        <span>/</span>
        <a href={withBase('assets')} class="hover:text-text-primary transition-colors">Assets</a>
        <span>/</span>
        <span class="text-text-secondary">{asset.title}</span>
      </nav>

      <div class="flex items-center gap-2 mb-3 flex-wrap">
        <span class="text-[9px] font-bold uppercase tracking-wider text-text-muted border border-border px-2 py-0.5 rounded-sm">{asset.category}</span>
        <span class="text-[9px] font-bold uppercase tracking-wider text-text-muted border border-border px-2 py-0.5 rounded-sm">{asset.sourceType}</span>
        <span class="text-[9px] font-bold uppercase tracking-wider text-text-muted border border-border px-2 py-0.5 rounded-sm">{asset.date}</span>
        {!asset.isPublic && (
          <span class="text-[9px] font-bold uppercase tracking-wider bg-accent/20 text-accent px-2 py-0.5 rounded-sm">Private</span>
        )}
      </div>

      <h1 class="font-display text-4xl md:text-6xl lg:text-7xl uppercase leading-none text-text-primary mb-4">{asset.title}</h1>
      <p class="text-text-secondary text-sm md:text-base max-w-2xl">{asset.summary}</p>

      <div class="flex items-center gap-4 mt-6 flex-wrap">
        <a
          href={withBase(asset.filePath)}
          download
          class="px-6 py-3 bg-accent hover:bg-accent-hover text-white text-xs font-bold uppercase tracking-widest transition-all duration-200 rounded-sm hover:shadow-[0_0_20px_rgba(230,0,18,0.3)]"
        >
          Download File
        </a>
        {asset.relatedArtSlug && (
          <a href={artPath(asset.relatedArtSlug)} class="px-6 py-3 border border-border hover:border-border-light text-text-secondary hover:text-text-primary text-xs font-bold uppercase tracking-widest transition-all duration-200 rounded-sm">
            View Related Art
          </a>
        )}
        <a href={withBase('assets')} class="px-6 py-3 border border-border hover:border-border-light text-text-secondary hover:text-text-primary text-xs font-bold uppercase tracking-widest transition-all duration-200 rounded-sm">
          &larr; Back to Assets
        </a>
      </div>
    </div>
    <div class="chrome-divider"></div>
  </section>

  <section class="bg-obsidian py-10">
    <div class="max-w-[var(--width-content)] mx-auto px-4 grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-8">
        <div class="surface-card rounded-sm p-6 md:p-8">
          <h2 class="font-display text-lg uppercase tracking-wider text-text-primary mb-4">Asset Notes</h2>
          <div class="chrome-divider mb-5"></div>
          <div class="space-y-4 text-sm text-text-secondary leading-relaxed [&>p]:mb-4 [&>h2]:font-display [&>h2]:text-text-primary [&>h2]:uppercase [&>h2]:mt-6 [&>h2]:mb-2 [&>h3]:font-display [&>h3]:text-text-primary [&>h3]:mt-4 [&>h3]:mb-2 [&>ul]:list-disc [&>ul]:pl-5 [&>ol]:list-decimal [&>ol]:pl-5 [&>a]:text-accent [&>a:hover]:text-accent-hover">
            <Content />
          </div>
        </div>
      </div>

      <div class="space-y-4">
        <div class="surface-card rounded-sm p-6">
          <h3 class="font-display text-sm uppercase tracking-wider text-text-primary mb-4">File Info</h3>
          <div class="chrome-divider mb-4"></div>
          <dl class="space-y-3">
            <div>
              <dt class="text-[9px] uppercase tracking-widest text-text-muted font-bold">Category</dt>
              <dd class="text-sm text-text-primary mt-0.5">{asset.category}</dd>
            </div>
            <div>
              <dt class="text-[9px] uppercase tracking-widest text-text-muted font-bold">Type</dt>
              <dd class="text-sm text-text-primary mt-0.5">{asset.sourceType}</dd>
            </div>
            <div>
              <dt class="text-[9px] uppercase tracking-widest text-text-muted font-bold">File</dt>
              <dd class="text-xs text-text-secondary mt-0.5 break-all">{asset.filePath}</dd>
            </div>
            {asset.tags.length > 0 && (
              <div>
                <dt class="text-[9px] uppercase tracking-widest text-text-muted font-bold">Tags</dt>
                <dd class="text-sm text-text-primary mt-0.5">{asset.tags.join(', ')}</dd>
              </div>
            )}
          </dl>
        </div>

        {related.length > 0 && (
          <div class="surface-card rounded-sm p-6">
            <h3 class="font-display text-sm uppercase tracking-wider text-text-primary mb-4">More Assets</h3>
            <div class="chrome-divider mb-4"></div>
            <div class="space-y-3">
              {related.map(item => (
                <a href={assetPath(item.slug)} class="flex items-center gap-3 group">
                  {item.previewImage ? (
                    <img src={withBase(item.previewImage)} alt={item.title}
                         class="w-14 h-10 object-cover rounded-sm border border-border group-hover:border-border-light transition-colors flex-shrink-0"
                         loading="lazy" />
                  ) : (
                    <div class="w-14 h-10 rounded-sm border border-border bg-gradient-to-br from-charcoal to-void flex-shrink-0"></div>
                  )}
                  <div class="min-w-0">
                    <p class="text-xs font-semibold text-text-primary truncate group-hover:text-accent transition-colors">{item.title}</p>
                    <p class="text-[9px] text-text-muted">{item.date}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <Footer />
</Layout>