---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import SubNav from '../../components/SubNav.astro';
import Footer from '../../components/Footer.astro';
import { fetchSoundCloudTracks } from '../../lib/soundcloud';

const SOUNDCLOUD_USER_ID = import.meta.env.SOUNDCLOUD_USER_ID || '70328358';
const tracks = await fetchSoundCloudTracks(SOUNDCLOUD_USER_ID, 16);
const latestTrack = tracks[0];
---

<Layout title="Music — Boink Brands" description="Original tracks, releases, and listening links from Boink Brands.">
  <Header />
  <SubNav activeTab="Music" />

  <section class="bg-void relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(230,0,18,0.08)_0%,transparent_70%)]"></div>
    <div class="relative max-w-[var(--width-content)] mx-auto px-4 py-16 md:py-20 text-center">
      <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-accent mb-3">Sound Lab</p>
      <h1 class="font-display text-4xl md:text-6xl uppercase leading-none tracking-tight mb-4">
        <span class="text-gradient">Music</span>
        <br />
        <span class="text-text-primary">Releases</span>
      </h1>
      <p class="text-text-secondary text-sm md:text-base max-w-lg mx-auto leading-relaxed mb-8">
        A focused catalog of tracks and sketches from the Boink Brands project. Stream directly here or open releases on SoundCloud.
      </p>

      <div class="flex items-center justify-center gap-3 flex-wrap">
        <a
          href={latestTrack?.href || 'https://soundcloud.com/boinkedup'}
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 bg-accent hover:bg-accent-hover text-white text-xs font-bold uppercase tracking-widest
                 transition-all duration-200 rounded-sm hover:shadow-[0_0_20px_rgba(230,0,18,0.3)]"
        >
          {latestTrack ? `Latest: ${latestTrack.title}` : 'Latest Release'}
        </a>
        <a
          href="https://soundcloud.com/boinkedup"
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 border border-border hover:border-border-light text-text-secondary hover:text-text-primary
                 text-xs font-bold uppercase tracking-widest transition-all duration-200 rounded-sm"
        >
          Open SoundCloud
        </a>
      </div>
    </div>
    <div class="chrome-divider"></div>
  </section>

  <section class="bg-obsidian py-8">
    <div class="max-w-[var(--width-content)] mx-auto px-4">
      <div class="surface-card rounded-sm overflow-hidden" id="track-player">
        <div class="flex items-center justify-between px-5 py-3 bg-charcoal border-b border-border">
          <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-text-secondary">Track Catalog</p>
          <span class="text-[9px] font-semibold uppercase tracking-wider text-text-muted border border-border px-2 py-0.5 rounded-sm">
            {tracks.length} Tracks
          </span>
        </div>

        <div class="divide-y divide-border" id="track-list">
          {tracks.map((track, index) => (
            <div
              class="track-row flex items-center gap-4 px-5 py-4 hover:bg-surface-hover transition-colors group cursor-pointer"
              data-index={index}
              data-stream={track.streamUrl}
              data-title={track.title}
              data-subtitle={track.subtitle}
              data-artwork={track.artwork}
              data-href={track.href}
              data-duration={track.duration}
            >
              <div class="relative w-12 h-12 flex-shrink-0">
                {track.artwork ? (
                  <img
                    src={track.artwork}
                    alt={track.title}
                    class="w-12 h-12 rounded-sm border border-border group-hover:border-accent/40 transition-colors object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-12 h-12 bg-charcoal rounded-sm border border-border group-hover:border-accent/40 transition-colors"></div>
                )}

                <div class="track-play-overlay absolute inset-0 flex items-center justify-center bg-black/50 rounded-sm opacity-0 group-hover:opacity-100 transition-opacity">
                  <svg class="play-icon w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"></path>
                  </svg>
                  <svg class="pause-icon w-5 h-5 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"></path>
                  </svg>
                </div>
              </div>

              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-text-primary truncate">{track.title}</p>
                <p class="text-xs text-text-muted">
                  {track.subtitle}
                  {track.duration && <span class="ml-2 text-text-muted/60">· {track.duration}</span>}
                </p>
              </div>

              {track.badge && (
                <span class="text-[9px] font-bold uppercase tracking-wider bg-accent/20 text-accent px-2 py-0.5 rounded-sm">
                  {track.badge}
                </span>
              )}

              <a
                href={track.href}
                target="_blank"
                rel="noopener noreferrer"
                class="sc-link text-text-muted hover:text-accent transition-colors opacity-0 group-hover:opacity-100"
                title="Open on SoundCloud"
                onclick="event.stopPropagation()"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M10 6V0H2v6H0v2h12V6h-2zm2 8.5V10H2v4.5a3.5 3.5 0 1 0 7 0V12h2v2.5a5.5 5.5 0 1 1-11 0V10H0v4.5C0 18.64 3.36 22 7.5 22S15 18.64 15 14.5V10h-3v4.5z" transform="scale(0.8) translate(3,1.5)"></path>
                  <path d="M7 2v18M3 6l4-4 4 4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" transform="translate(5,3) scale(0.7)"></path>
                </svg>
              </a>
            </div>
          ))}
        </div>

        <div id="mini-player" class="hidden border-t border-border bg-charcoal px-5 py-3">
          <div class="flex items-center gap-3">
            <button id="player-play-btn" class="text-white hover:text-accent transition-colors flex-shrink-0" aria-label="Play/Pause">
              <svg id="player-play-icon" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"></path>
              </svg>
              <svg id="player-pause-icon" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"></path>
              </svg>
            </button>

            <div class="flex-1 min-w-0">
              <p id="player-title" class="text-xs font-semibold text-text-primary truncate"></p>
              <div id="player-progress-container" class="mt-1 h-1 bg-border rounded-full cursor-pointer group/progress">
                <div id="player-progress" class="h-full bg-accent rounded-full transition-[width] duration-150 relative" style="width: 0%">
                  <div class="absolute right-0 top-1/2 -translate-y-1/2 w-2.5 h-2.5 bg-white rounded-full opacity-0 group-hover/progress:opacity-100 transition-opacity shadow-md"></div>
                </div>
              </div>
            </div>

            <span id="player-time" class="text-[10px] text-text-muted tabular-nums flex-shrink-0">0:00 / 0:00</span>
          </div>
        </div>

        <audio id="audio-el" preload="none"></audio>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const audio = document.getElementById('audio-el') as HTMLAudioElement;
  const miniPlayer = document.getElementById('mini-player')!;
  const trackRows = document.querySelectorAll('.track-row');
  const playerPlayBtn = document.getElementById('player-play-btn')!;
  const playerPlayIcon = document.getElementById('player-play-icon')!;
  const playerPauseIcon = document.getElementById('player-pause-icon')!;
  const playerTitle = document.getElementById('player-title')!;
  const playerProgress = document.getElementById('player-progress')!;
  const playerProgressContainer = document.getElementById('player-progress-container')!;
  const playerTime = document.getElementById('player-time')!;

  let currentIndex = -1;
  let isPlaying = false;

  function formatTime(sec: number): string {
    if (!isFinite(sec) || sec < 0) return '0:00';
    const m = Math.floor(sec / 60);
    const s = Math.floor(sec % 60);
    return `${m}:${s.toString().padStart(2, '0')}`;
  }

  function setActiveRow(index: number) {
    trackRows.forEach((row, i) => {
      const el = row as HTMLElement;
      if (i === index && isPlaying) {
        el.classList.add('bg-surface-hover');
        el.querySelector('.track-play-overlay')?.classList.add('!opacity-100');
        el.querySelector('.play-icon')?.classList.add('hidden');
        el.querySelector('.pause-icon')?.classList.remove('hidden');
      } else {
        el.classList.remove('bg-surface-hover');
        el.querySelector('.track-play-overlay')?.classList.remove('!opacity-100');
        el.querySelector('.play-icon')?.classList.remove('hidden');
        el.querySelector('.pause-icon')?.classList.add('hidden');
      }
    });
  }

  function updatePlayerUI() {
    if (isPlaying) {
      playerPlayIcon.classList.add('hidden');
      playerPauseIcon.classList.remove('hidden');
    } else {
      playerPlayIcon.classList.remove('hidden');
      playerPauseIcon.classList.add('hidden');
    }
    setActiveRow(currentIndex);
  }

  function playTrack(index: number) {
    const row = trackRows[index] as HTMLElement;
    if (!row) return;

    const streamUrl = row.dataset.stream;
    const title = row.dataset.title ?? 'Unknown';

    if (!streamUrl) {
      window.open(row.dataset.href, '_blank');
      return;
    }

    if (index === currentIndex) {
      if (isPlaying) {
        audio.pause();
        isPlaying = false;
      } else {
        audio.play();
        isPlaying = true;
      }
    } else {
      currentIndex = index;
      audio.src = streamUrl;
      audio.load();
      audio.play();
      isPlaying = true;

      playerTitle.textContent = title;
      miniPlayer.classList.remove('hidden');
    }

    updatePlayerUI();
  }

  trackRows.forEach((row, index) => {
    row.addEventListener('click', () => playTrack(index));
  });

  playerPlayBtn.addEventListener('click', () => {
    if (currentIndex === -1) return;
    if (audio.paused) {
      audio.play();
      isPlaying = true;
    } else {
      audio.pause();
      isPlaying = false;
    }
    updatePlayerUI();
  });

  audio.addEventListener('timeupdate', () => {
    const duration = audio.duration || 0;
    const current = audio.currentTime || 0;
    const pct = duration > 0 ? (current / duration) * 100 : 0;
    (playerProgress as HTMLElement).style.width = `${pct}%`;
    playerTime.textContent = `${formatTime(current)} / ${formatTime(duration)}`;
  });

  audio.addEventListener('ended', () => {
    isPlaying = false;
    updatePlayerUI();
  });

  audio.addEventListener('play', () => {
    isPlaying = true;
    updatePlayerUI();
  });

  audio.addEventListener('pause', () => {
    isPlaying = false;
    updatePlayerUI();
  });

  playerProgressContainer.addEventListener('click', (event) => {
    const rect = (event.currentTarget as HTMLElement).getBoundingClientRect();
    const clickX = event.clientX - rect.left;
    const pct = Math.min(Math.max(clickX / rect.width, 0), 1);
    if (audio.duration) audio.currentTime = pct * audio.duration;
  });
</script>